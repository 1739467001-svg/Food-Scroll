# ==========================================
# 鼎味轩 - 环境变量配置文件
# 复制此文件为 .env 并修改实际值
# 所有云平台都支持这些环境变量
# ==========================================

# ==========================================
# 必需配置（生产环境必须设置）
# ==========================================

# JWT 密钥（生产环境务必修改！长度建议 32 字符以上）
# 生成随机密钥: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ==========================================
# 可选配置（使用默认值即可）
# ==========================================

# 运行环境
NODE_ENV=production

# 服务端口（云平台通常自动设置 PORT）
PORT=3001

# 数据库路径（Docker 中使用 /app/data/database.sqlite）
DB_PATH=./data/database.sqlite

# 上传文件路径（Docker 中使用 /app/uploads）
UPLOAD_PATH=./uploads

# CORS 跨域配置
# 开发环境: *
# 生产环境: https://your-domain.com,https://www.your-domain.com
CORS_ORIGIN=*

# ==========================================
# 前端环境变量（构建时注入）
# ==========================================

# API 基础路径（通常不需要修改）
VITE_API_URL=/api

# 应用标题
VITE_APP_TITLE=鼎味轩

# ==========================================
# 云平台特定配置（根据平台选择性设置）
# ==========================================

# Zeabur 自动注入的环境变量（不需要手动设置）
# ZEABUR_WEB_DOMAIN
# ZEABUR_BACKEND_URL

# Railway 自动注入的环境变量
# RAILWAY_STATIC_URL
# RAILWAY_ENVIRONMENT

# Fly.io 自动注入的环境变量
# FLY_APP_NAME
# FLY_REGION

# ==========================================
# 可选：对象存储配置（推荐用于生产环境）
# 使用阿里云 OSS/腾讯云 COS 替代本地存储
# ==========================================

# 阿里云 OSS
# ALIYUN_OSS_REGION=oss-cn-beijing
# ALIYUN_OSS_BUCKET=your-bucket-name
# ALIYUN_OSS_ACCESS_KEY_ID=your-access-key
# ALIYUN_OSS_ACCESS_KEY_SECRET=your-secret-key
# ALIYUN_OSS_ENDPOINT=https://your-bucket.oss-cn-beijing.aliyuncs.com

# 腾讯云 COS
# TENCENT_COS_REGION=ap-beijing
# TENCENT_COS_BUCKET=your-bucket-name
# TENCENT_COS_SECRET_ID=your-secret-id
# TENCENT_COS_SECRET_KEY=your-secret-key

# ==========================================
# 可选：监控和日志
# ==========================================

# Sentry 错误监控（可选）
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Logtail 日志（可选）
# LOGTAIL_SOURCE_TOKEN=your-token

# ==========================================
# 可选：通知配置
# ==========================================

# Watchtower 更新通知
# WATCHTOWER_NOTIFICATION_URL=discord://token@id
